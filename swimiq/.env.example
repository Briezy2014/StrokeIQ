SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Video Engine V2 (Elite Video Lab) — never put Gemini or service-role keys here
# Elote measures the swim; Gemini only writes the coaching plan from metrics.
ANALYSIS_API_BASE_URL=http://localhost:8080
# Set true once Elote is running and Supabase migrations 005–007 are applied
VIDEO_ENGINE_V2=true
# Optional extra emails. Master + demo always get Elite Video Lab when V2 is on.
VIDEO_ENGINE_V2_ALLOWLIST=
# Keep false in production. true = also show legacy Edge Function Analyze button
VIDEO_ENGINE_V2_DUAL_RUN=false
