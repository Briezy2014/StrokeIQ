# Elote Video Lab — analysis service (Milestone 2)
# Copy to .env and adjust. Never commit real secrets.

ENGINE_VERSION=elote-0.5.0
ARTIFACT_ROOT=./analysis_artifacts
JOB_STORE_PATH=./analysis_artifacts/jobs.json
MAX_VIDEO_BYTES=524288000
MIN_WIDTH=320
MIN_HEIGHT=240
MIN_FPS=15.0
MIN_DURATION_MS=200
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
LOG_LEVEL=INFO

# Detection / tracking
DETECTOR_BACKEND=rtmdet_onnx
DETECTOR_MODEL_PATH=models/rtmdet-n-person.onnx
MIN_DETECTION_CONFIDENCE=0.35
TRACKING_CONFIDENCE_THRESHOLD=0.40
MAX_LOST_FRAMES=15
MAX_TARGET_LOST_FRAMES=45
FRAME_PROCESSING_INTERVAL=1
INFERENCE_RESOLUTION=320
MAX_ACTIVE_TRACKS=12

# Pose (Milestone 3) — stages do not auto-advance
POSE_ENABLED=false
POSE_STAGE=A
POSE_DEVICE=cpu
POSE_CONFIG_PATH=models/rtmpose/rtmpose-m_8xb64-270e_coco-wholebody-256x192.py
POSE_CHECKPOINT_PATH=models/rtmpose/rtmpose-m_simcc-coco-wholebody_pt-aic-coco_270e-256x192-cd5e845c_20230123.pth
MIN_KEYPOINT_CONFIDENCE=0.30
MIN_VISIBLE_CORE_JOINTS=6

# Pose validation / smoothing (Milestone 4)
POSE_SMOOTHING_ENABLED=true
MAX_INTERPOLATION_GAP_FRAMES=3
MAX_JOINT_VELOCITY_PX_S=2500.0
MAX_JOINT_ACCELERATION_PX_S2=80000.0
CONTINUITY_MAX_JUMP_PX=100.0
SAVGOL_WINDOW=5
SAVGOL_POLYORDER=2
LONG_OCCLUSION_GAP_FRAMES=8
USABLE_FRAME_MIN_CORE_JOINTS=4
USABLE_FRAME_MIN_CONFIDENCE=0.20
OVERLAY_MIN_DRAW_CONFIDENCE=0.25
DIAGNOSTIC_FRAME_COUNT=12

# Butterfly surface analysis (Milestone 5)
BUTTERFLY_ANALYSIS_ENABLED=false
BUTTERFLY_MIN_CYCLE_DURATION_S=0.70
BUTTERFLY_MAX_CYCLE_DURATION_S=2.20
BUTTERFLY_MIN_PEAK_PROMINENCE=0.08
BUTTERFLY_MIN_BILATERAL_SYNC=0.25
POOL_DISTANCE_CALIBRATED=false
