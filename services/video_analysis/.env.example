# Elote Video Lab — analysis service (Milestone 1)
# Copy to .env and adjust. Never commit real secrets.

ENGINE_VERSION=elote-0.1.0
ARTIFACT_ROOT=./analysis_artifacts
JOB_STORE_PATH=./analysis_artifacts/jobs.json
MAX_VIDEO_BYTES=524288000
MIN_WIDTH=320
MIN_HEIGHT=240
MIN_FPS=15.0
MIN_DURATION_MS=200
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
LOG_LEVEL=INFO
# Optional for later milestones:
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# GEMINI_API_KEY=
