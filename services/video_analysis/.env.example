# Elite Video Lab — analysis service (Milestone 2)
# Copy to .env and adjust. Never commit real secrets.

ENGINE_VERSION=elite-0.9.0
ARTIFACT_ROOT=./analysis_artifacts
JOB_STORE_PATH=./analysis_artifacts/jobs.json
MAX_VIDEO_BYTES=524288000
MIN_WIDTH=320
MIN_HEIGHT=240
MIN_FPS=15.0
MIN_DURATION_MS=200
FFPROBE_PATH=ffprobe
FFMPEG_PATH=ffmpeg
LOG_LEVEL=INFO

# Detection / tracking
DETECTOR_BACKEND=rtmdet_onnx
DETECTOR_MODEL_PATH=models/rtmdet-n-person.onnx
MIN_DETECTION_CONFIDENCE=0.25
TRACKING_CONFIDENCE_THRESHOLD=0.30
MAX_LOST_FRAMES=30
MAX_TARGET_LOST_FRAMES=120
MIN_USABLE_TARGET_COVERAGE=0.08
FRAME_PROCESSING_INTERVAL=3
MAX_ANALYSIS_DURATION_S=45
ANNOTATED_FRAME_STRIDE=2
INFERENCE_RESOLUTION=320
MAX_ACTIVE_TRACKS=12

# Pose (Milestone 3) — stages do not auto-advance
POSE_ENABLED=false
POSE_STAGE=A
POSE_DEVICE=cpu
POSE_CONFIG_PATH=models/rtmpose/rtmpose-m_8xb64-270e_coco-wholebody-256x192.py
POSE_CHECKPOINT_PATH=models/rtmpose/rtmpose-m_simcc-coco-wholebody_pt-aic-coco_270e-256x192-cd5e845c_20230123.pth
MIN_KEYPOINT_CONFIDENCE=0.30
MIN_VISIBLE_CORE_JOINTS=6

# Pose validation / smoothing (Milestone 4)
POSE_SMOOTHING_ENABLED=true
MAX_INTERPOLATION_GAP_FRAMES=3
MAX_JOINT_VELOCITY_PX_S=2500.0
MAX_JOINT_ACCELERATION_PX_S2=80000.0
CONTINUITY_MAX_JUMP_PX=100.0
SAVGOL_WINDOW=5
SAVGOL_POLYORDER=2
LONG_OCCLUSION_GAP_FRAMES=8
USABLE_FRAME_MIN_CORE_JOINTS=4
USABLE_FRAME_MIN_CONFIDENCE=0.20
OVERLAY_MIN_DRAW_CONFIDENCE=0.25
DIAGNOSTIC_FRAME_COUNT=12

# Butterfly surface analysis (Milestone 5)
BUTTERFLY_ANALYSIS_ENABLED=false
BUTTERFLY_MIN_CYCLE_DURATION_S=0.70
BUTTERFLY_MAX_CYCLE_DURATION_S=2.20
BUTTERFLY_MIN_PEAK_PROMINENCE=0.08
BUTTERFLY_MIN_BILATERAL_SYNC=0.25
POOL_DISTANCE_CALIBRATED=false

# Underwater / breakout (Milestone 6)
UNDERWATER_ANALYSIS_ENABLED=false
UNDERWATER_MIN_KICK_INTERVAL_S=0.28
UNDERWATER_MAX_KICK_INTERVAL_S=1.10
UNDERWATER_KICK_PROMINENCE_PX=4.0
UNDERWATER_MIN_DURATION_S=0.40

# Turn / finish framework (Milestone 7)
TURN_ANALYSIS_ENABLED=false
FINISH_ANALYSIS_ENABLED=false

# Gemini coaching report (Milestone 8) — backend only; never expose to Flutter
GEMINI_REPORT_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_TIMEOUT_S=45
GEMINI_MAX_REGENERATE_ATTEMPTS=2
GEMINI_ATTACH_EVIDENCE_IMAGES=false

# Milestone 9 — Supabase / Flutter (backend secrets only; never ship to Flutter)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUTH_REQUIRED=false
SUPABASE_PERSIST_RESULTS=false
SUPABASE_SIGNED_URL_TTL_S=3600
VIDEO_ENGINE_NAME=video_engine_v2
CORS_ALLOW_ORIGINS=*
# Optional: extra emails only. Master briezy682014@gmail.com + demo@swimiqapp.com
# are always allowed. Leave empty so coach-code / trial users can call the API.
VIDEO_ENGINE_V2_ALLOWLIST=
